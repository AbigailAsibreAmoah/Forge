# Forge Backend — Environment Variables
# Copy this file to .env and add your keys
# Get a free Groq key at: https://console.groq.com
GROQ_API_KEY=gsk_your-key-here

# Required for stable sessions across restarts
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string

# Paystack — get these from https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_live_your-secret-key-here

# The URL of your Paystack payment page / hosted checkout
# e.g. https://paystack.com/pay/forge-pro
UPGRADE_URL=https://paystack.com/pay/forge-pro

# Optional: override database path (default: /data/forge.db)
# DB_PATH=/data/forge.db
